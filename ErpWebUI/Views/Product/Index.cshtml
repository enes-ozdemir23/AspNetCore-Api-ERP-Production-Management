@model List<ResultStockDto>
@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/UILayout/Index.cshtml";
}

@* @await Component.InvokeAsync("_DefaultFeatureComponentPartial")
 *@

<div class="untree_co-section product-section before-footer-section">
	<div class="container">
		<div class="row">

			@foreach(var item in Model)
			{
							
			<div class="col-12 col-md-4 col-lg-3 mb-5">
				<a class="product-item" href="#">
						<img src="/furni-1.0.0/images/product-3.png" class="img-fluid product-thumbnail">
					<h3 class="product-title">@item.StockName</h3>
					<strong class="product-price">$50.00 @item.GroupCode</strong>

					<span class="icon-cross">
						<img src="/furni-1.0.0/images/cross.svg" class="img-fluid">
					</span>
				</a>
			</div>

			}

		</div>
	</div>
</div>
